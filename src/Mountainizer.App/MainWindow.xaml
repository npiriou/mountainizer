<Window x:Class="Mountainizer.Editor.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:gl="clr-namespace:OpenTK.Wpf;assembly=GLWpfControl"
 Title="Mountainizer — SSX 3 Level Inspector (Read-only)" Icon="Assets/mountainizer.ico" Width="1540" Height="940" MinWidth="1120" MinHeight="720"
 Background="#082F43" Foreground="#F4FBFD" FontFamily="Bahnschrift, Segoe UI" KeyDown="Window_KeyDown">
 <Window.Resources>
  <Color x:Key="NavyColor">#062B3D</Color>
  <Color x:Key="DeepBlueColor">#0B4560</Color>
  <Color x:Key="CyanColor">#2096BF</Color>
  <Color x:Key="IceColor">#DDF3F7</Color>
  <Color x:Key="OrangeColor">#F05A00</Color>
  <SolidColorBrush x:Key="Navy" Color="{StaticResource NavyColor}"/>
  <SolidColorBrush x:Key="DeepBlue" Color="{StaticResource DeepBlueColor}"/>
  <SolidColorBrush x:Key="Cyan" Color="{StaticResource CyanColor}"/>
  <SolidColorBrush x:Key="Ice" Color="{StaticResource IceColor}"/>
  <SolidColorBrush x:Key="Orange" Color="{StaticResource OrangeColor}"/>
  <SolidColorBrush x:Key="Panel" Color="#D914536E"/>
  <SolidColorBrush x:Key="PanelDark" Color="#E8072C3E"/>
  <LinearGradientBrush x:Key="WindowGradient" StartPoint="0,0" EndPoint="1,1">
   <GradientStop Color="#0A5A78" Offset="0"/><GradientStop Color="#0A3E58" Offset="0.48"/><GradientStop Color="#052637" Offset="1"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="IceGradient" StartPoint="0,0" EndPoint="1,0">
   <GradientStop Color="#F2FCFD" Offset="0"/><GradientStop Color="#B9DDE6" Offset="1"/>
  </LinearGradientBrush>

  <Style TargetType="Button">
   <Setter Property="FontFamily" Value="Bahnschrift, Segoe UI"/><Setter Property="FontWeight" Value="SemiBold"/>
   <Setter Property="Foreground" Value="{StaticResource Navy}"/><Setter Property="Background" Value="{StaticResource Ice}"/>
   <Setter Property="BorderBrush" Value="#80FFFFFF"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="12,6"/><Setter Property="Margin" Value="3"/>
   <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{StaticResource Orange}"/><Setter Property="Foreground" Value="White"/></Trigger></Style.Triggers>
  </Style>
  <Style TargetType="TextBox">
   <Setter Property="FontFamily" Value="Bahnschrift, Segoe UI"/><Setter Property="Background" Value="#ECF8FA"/><Setter Property="Foreground" Value="{StaticResource Navy}"/>
   <Setter Property="BorderBrush" Value="#63B7CC"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="8,5"/><Setter Property="CaretBrush" Value="{StaticResource Orange}"/>
  </Style>
  <Style TargetType="ComboBox">
   <Setter Property="FontFamily" Value="Bahnschrift, Segoe UI"/><Setter Property="FontSize" Value="14"/><Setter Property="FontWeight" Value="SemiBold"/>
   <Setter Property="Background" Value="White"/><Setter Property="Foreground" Value="{StaticResource Navy}"/><Setter Property="BorderBrush" Value="{StaticResource Orange}"/>
   <Setter Property="BorderThickness" Value="2"/><Setter Property="Padding" Value="10,5"/>
  </Style>
  <Style TargetType="TreeViewItem">
   <Setter Property="FontFamily" Value="Bahnschrift, Segoe UI"/><Setter Property="Foreground" Value="#E9F8FB"/><Setter Property="Padding" Value="2,3"/><Setter Property="Margin" Value="0,1"/>
   <Style.Triggers><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="{StaticResource Orange}"/><Setter Property="Foreground" Value="White"/><Setter Property="FontWeight" Value="SemiBold"/></Trigger></Style.Triggers>
  </Style>
  <Style TargetType="ListViewItem">
   <Setter Property="FontFamily" Value="Bahnschrift, Segoe UI"/><Setter Property="Foreground" Value="#E9F8FB"/><Setter Property="Padding" Value="7,5"/>
   <Style.Triggers><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="{StaticResource Orange}"/><Setter Property="Foreground" Value="White"/></Trigger><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#3A8AA5"/></Trigger></Style.Triggers>
  </Style>
  <Style TargetType="DataGrid">
   <Setter Property="FontFamily" Value="Bahnschrift, Segoe UI"/><Setter Property="Background" Value="#E9F6F8"/><Setter Property="Foreground" Value="{StaticResource Navy}"/>
   <Setter Property="RowBackground" Value="#E9F6F8"/><Setter Property="AlternatingRowBackground" Value="#CBE7ED"/><Setter Property="GridLinesVisibility" Value="Horizontal"/>
   <Setter Property="HorizontalGridLinesBrush" Value="#79AFC0"/><Setter Property="BorderThickness" Value="0"/><Setter Property="IsReadOnly" Value="True"/><Setter Property="HeadersVisibility" Value="Column"/>
  </Style>
  <Style TargetType="DataGridColumnHeader">
   <Setter Property="FontFamily" Value="Bahnschrift, Segoe UI"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="#176B88"/>
   <Setter Property="Padding" Value="8,6"/><Setter Property="BorderBrush" Value="#64A7BC"/><Setter Property="BorderThickness" Value="0,0,1,1"/>
  </Style>
  <Style TargetType="TabControl">
   <Setter Property="Background" Value="{StaticResource PanelDark}"/><Setter Property="BorderThickness" Value="0"/>
   <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TabControl">
    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
     <Border Grid.Row="0" Background="#0C3C52" BorderBrush="#6AC4D8" BorderThickness="0,0,0,2"><TabPanel IsItemsHost="True" Margin="5,4,5,0"/></Border>
     <Border Grid.Row="1" Background="{TemplateBinding Background}" BorderBrush="#5FB8CF" BorderThickness="1,0,1,1"><ContentPresenter ContentSource="SelectedContent" Margin="4"/></Border>
    </Grid>
   </ControlTemplate></Setter.Value></Setter>
  </Style>
  <Style TargetType="TabItem">
   <Setter Property="FontFamily" Value="Bahnschrift, Segoe UI"/><Setter Property="FontSize" Value="13"/><Setter Property="FontWeight" Value="SemiBold"/>
   <Setter Property="Foreground" Value="#BFE3EB"/><Setter Property="Background" Value="#16536A"/><Setter Property="Padding" Value="16,7"/><Setter Property="Margin" Value="0,0,4,0"/>
   <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TabItem">
    <Border x:Name="TabBorder" Background="{TemplateBinding Background}" CornerRadius="0,12,0,0" Padding="{TemplateBinding Padding}"><ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/></Border>
    <ControlTemplate.Triggers><Trigger Property="IsSelected" Value="True"><Setter TargetName="TabBorder" Property="Background" Value="{StaticResource Orange}"/><Setter Property="Foreground" Value="White"/></Trigger><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="TabBorder" Property="Background" Value="#2B9ABB"/><Setter Property="Foreground" Value="White"/></Trigger></ControlTemplate.Triggers>
   </ControlTemplate></Setter.Value></Setter>
  </Style>
  <Style TargetType="Menu"><Setter Property="FontFamily" Value="Bahnschrift, Segoe UI"/><Setter Property="Background" Value="Transparent"/></Style>
  <Style TargetType="MenuItem">
   <Setter Property="FontFamily" Value="Bahnschrift, Segoe UI"/><Setter Property="FontSize" Value="13"/><Setter Property="Padding" Value="12,7"/><Setter Property="Foreground" Value="White"/>
   <Style.Triggers>
    <Trigger Property="Role" Value="SubmenuItem"><Setter Property="Foreground" Value="{StaticResource Navy}"/><Setter Property="Background" Value="#EFFAFC"/></Trigger>
    <Trigger Property="Role" Value="SubmenuHeader"><Setter Property="Foreground" Value="{StaticResource Navy}"/><Setter Property="Background" Value="#EFFAFC"/></Trigger>
    <Trigger Property="IsHighlighted" Value="True"><Setter Property="Background" Value="{StaticResource Orange}"/><Setter Property="Foreground" Value="White"/></Trigger>
   </Style.Triggers>
  </Style>
  <Style TargetType="GridSplitter"><Setter Property="Background" Value="#3B91A9"/></Style>
 </Window.Resources>

 <Grid Background="{StaticResource WindowGradient}">
  <Grid.RowDefinitions><RowDefinition Height="76"/><RowDefinition Height="52"/><RowDefinition Height="*"/><RowDefinition Height="30"/></Grid.RowDefinitions>

  <!-- SSX-inspired masthead -->
  <Grid Grid.Row="0" ClipToBounds="True">
   <Grid.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#0A6685" Offset="0"/><GradientStop Color="#073247" Offset="1"/></LinearGradientBrush></Grid.Background>
   <Polygon Points="0,0 405,0 462,38 405,76 0,76" Fill="{StaticResource Orange}"/>
   <Polygon Points="0,68 420,68 449,76 0,76" Fill="#B53A00"/>
   <StackPanel Margin="26,12,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
    <TextBlock Text="M O U N T A I N I Z E R" FontSize="24" FontWeight="Bold" FontStretch="Expanded" Foreground="White"/>
    <TextBlock Text="//  SSX 3 WORLD INSPECTOR" FontSize="12" Foreground="#FFF1E7" Margin="2,-1,0,0"/>
   </StackPanel>
   <Menu HorizontalAlignment="Left" VerticalAlignment="Center" Margin="475,0,0,0">
    <MenuItem Header="FILE"><MenuItem Header="Import SSX 3 ISO…" Click="ImportIso_Click"/><MenuItem Header="Open project…" Click="OpenProject_Click"/><Separator/><MenuItem Header="Export scene OBJ…" Click="ExportObj_Click"/><MenuItem Header="Export diagnostics JSON…" Click="ExportDiagnostics_Click"/><Separator/><MenuItem Header="Exit" Click="Exit_Click"/></MenuItem>
    <MenuItem Header="VIEW"><MenuItem Header="Terrain" IsCheckable="True" IsChecked="True" Click="Terrain_Click"/><MenuItem Header="Props and models" IsCheckable="True" IsChecked="True" Click="Props_Click"/><MenuItem Header="Splines (debug)" IsCheckable="True" Click="Splines_Click"/><MenuItem Header="Triggers (debug)" IsCheckable="True" Click="Triggers_Click"/><MenuItem Header="Visibility curtains (debug)" IsCheckable="True" Click="Visibility_Click"/><Separator/><MenuItem Header="Wireframe" IsCheckable="True" Click="Wireframe_Click"/><MenuItem Header="Backface culling" IsCheckable="True" IsChecked="True" Click="Culling_Click"/><MenuItem Header="Grid" IsCheckable="True" IsChecked="True" Click="Grid_Click"/><MenuItem Header="Frame scene (F)" Click="Frame_Click"/></MenuItem>
    <MenuItem Header="HELP"><MenuItem Header="Controls" Click="Controls_Click"/></MenuItem>
   </Menu>
   <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
    <TextBlock Text="READ-ONLY  /  PS2 NTSC-U" Foreground="#A8DDE8" FontSize="11" HorizontalAlignment="Right"/>
    <TextBlock Text="LEVEL LAB  03" Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Right"/>
   </StackPanel>
   <TextBlock Text="✦" FontSize="44" Foreground="#265F75" Opacity="0.65" HorizontalAlignment="Right" Margin="0,-12,178,0"/>
  </Grid>

  <!-- Course rail -->
  <Border Grid.Row="1" Background="{StaticResource IceGradient}" BorderBrush="#FFFFFF" BorderThickness="0,1,0,1">
   <Grid Margin="18,5"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="440"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
    <Border Grid.Column="0" Background="{StaticResource Orange}" CornerRadius="0,15,15,0" Padding="18,7" Margin="-18,0,12,0"><TextBlock Text="S E L E C T  C O U R S E" Foreground="White" FontWeight="Bold" FontSize="12"/></Border>
    <ComboBox Grid.Column="1" x:Name="LevelPicker" Margin="0,0,14,0" SelectionChanged="LevelPicker_SelectionChanged"/>
    <TextBlock Grid.Column="2" x:Name="StatusText" Foreground="{StaticResource Navy}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Text="No project open"/>
    <Border Grid.Column="3" Background="#143F52" CornerRadius="13,0,0,13" Padding="14,6" Margin="12,0,-18,0"><StackPanel Orientation="Horizontal"><Ellipse Width="8" Height="8" Fill="#50E6A8" Margin="0,0,7,0"/><TextBlock Text="SOURCE SAFE" Foreground="White" FontSize="11" FontWeight="SemiBold"/></StackPanel></Border>
   </Grid>
  </Border>

  <!-- Main workbench -->
  <Grid Grid.Row="2" Margin="12,10,12,8">
   <Grid.ColumnDefinitions><ColumnDefinition Width="302" MinWidth="220"/><ColumnDefinition Width="7"/><ColumnDefinition Width="*"/><ColumnDefinition Width="7"/><ColumnDefinition Width="370" MinWidth="280"/></Grid.ColumnDefinitions>
   <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="7"/><RowDefinition Height="252" MinHeight="145"/></Grid.RowDefinitions>

   <Border Grid.Column="0" Grid.RowSpan="3" Background="{StaticResource Panel}" BorderBrush="#8BD4E2" BorderThickness="1" CornerRadius="0,22,0,0">
    <Grid><Grid.RowDefinitions><RowDefinition Height="42"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
     <Grid Grid.Row="0" ClipToBounds="True"><Border Background="{StaticResource Orange}" CornerRadius="0,18,18,0" Width="236" HorizontalAlignment="Left"><StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0"><TextBlock Text="▲" Foreground="White" FontSize="13" Margin="0,0,9,0"/><TextBlock Text="S C E N E  C O N T E N T" Foreground="White" FontWeight="Bold" FontSize="12"/></StackPanel></Border><TextBlock Text="01" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0" Foreground="#73BCD0" FontSize="18" FontWeight="Bold"/></Grid>
     <Grid Grid.Row="1" Margin="10,9,10,8"><TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged" ToolTip="Filter scene items" Padding="28,6,8,6"/><TextBlock Text="⌕" Foreground="#277A96" FontSize="17" Margin="8,2,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/></Grid>
     <TreeView Grid.Row="2" x:Name="SceneTree" Margin="7,0,7,8" Padding="5" Background="#B80A354A" BorderThickness="0" Foreground="#E9F8FB" SelectedItemChanged="SceneTree_SelectedItemChanged" MouseDoubleClick="SceneTree_MouseDoubleClick"/>
    </Grid>
   </Border>
   <GridSplitter Grid.Column="1" Grid.RowSpan="3" HorizontalAlignment="Stretch"/>

   <Border Grid.Column="2" Grid.Row="0" Background="#061119" BorderBrush="#B9ECF3" BorderThickness="2" CornerRadius="0,18,0,0">
    <Grid Margin="4">
     <gl:GLWpfControl x:Name="GlViewport" Render="GlViewport_Render" MouseDown="Viewport_MouseDown" MouseUp="Viewport_MouseUp" MouseMove="Viewport_MouseMove" MouseWheel="Viewport_MouseWheel" Focusable="True"><gl:GLWpfControl.Settings><gl:GLWpfControlSettings MajorVersion="3" MinorVersion="3" RenderContinuously="True"/></gl:GLWpfControl.Settings></gl:GLWpfControl>
     <Border HorizontalAlignment="Left" VerticalAlignment="Top" Background="#D9F05A00" CornerRadius="0,0,14,0" Padding="13,6" IsHitTestVisible="False"><TextBlock Text="3D  WORLD  VIEW" Foreground="White" FontWeight="Bold" FontSize="12"/></Border>
     <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="#B9062B3D" CornerRadius="12,0,0,0" Padding="11,5" IsHitTestVisible="False"><TextBlock Text="LMB SELECT  •  RMB SURFACE ORBIT  •  WHEEL ZOOM  •  F FRAME" Foreground="#BCE6EF" FontSize="10"/></Border>
    </Grid>
   </Border>
   <GridSplitter Grid.Column="3" Grid.RowSpan="3" HorizontalAlignment="Stretch"/>

   <Border Grid.Column="4" Grid.RowSpan="3" Background="{StaticResource Panel}" BorderBrush="#8BD4E2" BorderThickness="1" CornerRadius="22,0,0,0">
    <Grid><Grid.RowDefinitions><RowDefinition Height="42"/><RowDefinition Height="*"/></Grid.RowDefinitions>
     <Grid Grid.Row="0"><TextBlock Text="02" VerticalAlignment="Center" Margin="14,0,0,0" Foreground="#73BCD0" FontSize="18" FontWeight="Bold"/><Border Background="{StaticResource Orange}" CornerRadius="18,0,0,18" Width="250" HorizontalAlignment="Right"><TextBlock Text="O B J E C T  /  A S S E T" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></Grid>
     <TabControl Grid.Row="1" Margin="7,0,7,8">
      <TabItem Header="PROPERTIES"><DataGrid x:Name="PropertyGrid" AutoGenerateColumns="False"><DataGrid.Columns><DataGridTextColumn Header="FIELD" Binding="{Binding Key}" Width="145"/><DataGridTextColumn Header="VALUE" Binding="{Binding Value}" Width="*"/></DataGrid.Columns></DataGrid></TabItem>
      <TabItem Header="ASSETS"><Grid><Grid.RowDefinitions><RowDefinition Height="230"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><Border Grid.Row="0" Margin="4" Background="#061119" BorderBrush="#5CAFC4" BorderThickness="1"><Image x:Name="TexturePreview" Stretch="Uniform"/></Border><TextBlock x:Name="AssetDetails" Grid.Row="1" Margin="7" Foreground="#DDF3F7" Text="Select a decoded texture to preview it." TextWrapping="Wrap"/><ListView x:Name="AssetList" Grid.Row="2" Background="#A70A354A" BorderThickness="0" Foreground="#E9F8FB" SelectionChanged="AssetList_SelectionChanged" DisplayMemberPath="DisplayName"/></Grid></TabItem>
     </TabControl>
    </Grid>
   </Border>

   <GridSplitter Grid.Column="2" Grid.Row="1" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
   <Border Grid.Column="2" Grid.Row="2" Background="{StaticResource Panel}" BorderBrush="#8BD4E2" BorderThickness="1" CornerRadius="0,0,18,0">
    <TabControl Margin="5">
     <TabItem Header="FORMAT DIAGNOSTICS"><DataGrid x:Name="DiagnosticsGrid" AutoGenerateColumns="True"/></TabItem>
     <TabItem Header="ACTIVITY LOG"><TextBox x:Name="LogBox" IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Background="#071F2C" Foreground="#D7F1F6" BorderThickness="0" FontFamily="Cascadia Mono, Consolas" FontSize="11"/></TabItem>
    </TabControl>
   </Border>
  </Grid>

  <StatusBar Grid.Row="3" Background="#061F2C" Foreground="#C9EAF0" BorderBrush="#237C99" BorderThickness="0,1,0,0" Padding="8,2">
   <StatusBarItem><TextBlock x:Name="ProgressText" Text="READY  //  WAITING FOR SOURCE" FontSize="11" FontWeight="SemiBold"/></StatusBarItem><Separator/>
   <StatusBarItem HorizontalAlignment="Right"><ProgressBar x:Name="ProgressBar" Width="250" Height="9" Minimum="0" Maximum="100" Foreground="{StaticResource Orange}" Background="#123E50" BorderThickness="0"/></StatusBarItem>
  </StatusBar>
 </Grid>
</Window>
